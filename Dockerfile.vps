# Browser must reach API host:ports from outside Docker — pass NEXT_PUBLIC_* at build time (see pramool-core deploy/vps).
FROM node:22-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install

FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

ARG NEXT_PUBLIC_CORE_API_BASE_URL
ARG NEXT_PUBLIC_USER_API_BASE_URL
ARG NEXT_PUBLIC_WALLET_API_BASE_URL
ARG NEXT_PUBLIC_AUCTION_REALTIME_BASE_URL
ENV NEXT_PUBLIC_CORE_API_BASE_URL=$NEXT_PUBLIC_CORE_API_BASE_URL
ENV NEXT_PUBLIC_USER_API_BASE_URL=$NEXT_PUBLIC_USER_API_BASE_URL
ENV NEXT_PUBLIC_WALLET_API_BASE_URL=$NEXT_PUBLIC_WALLET_API_BASE_URL
ENV NEXT_PUBLIC_AUCTION_REALTIME_BASE_URL=$NEXT_PUBLIC_AUCTION_REALTIME_BASE_URL

RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
CMD ["node", "server.js"]
